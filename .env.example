# 1. Получить у @BotFather в Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# 2. Получить на console.groq.com (бесплатно)
GROQ_API_KEY=your_groq_api_key_here

# 3. Свой Telegram ID — узнать у @userinfobot
MY_TELEGRAM_ID=123456789

# 4. Строка подключения к PostgreSQL (обязательно)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# 5. Таймзона — в ней бот понимает «завтра в 9» и шлёт напоминания
TIMEZONE=Europe/Moscow

# 6. Порт health-check сервера. На хостинге задаётся автоматически.
# PORT=8080

# 7. Размер пула соединений к БД
# DB_POOL_MAX=5
