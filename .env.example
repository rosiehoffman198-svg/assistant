# 1. Получить у @BotFather в Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# 2. Получить на console.groq.com (бесплатно)
GROQ_API_KEY=your_groq_api_key_here

# 3. Свой Telegram ID — узнать у @userinfobot
MY_TELEGRAM_ID=123456789

# 4. Путь к базе (менять не нужно)
DB_PATH=assistant.db

# 5. Модель (менять не нужно)
MODEL=llama-3.3-70b-versatile
